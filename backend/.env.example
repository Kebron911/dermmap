# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dermmap
DB_USER=postgres
DB_PASSWORD=postgres

# Alternative: provide a full connection string instead of individual vars above.
# node-pg-migrate and the migration runner will use this when set.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/dermmap

# Database TLS — set DB_SSL=true in cloud/production deployments (HIPAA §164.312(e)(1))
# When DB_SSL=true and DB_SSL_REJECT_UNAUTHORIZED=false, self-signed certs are accepted.
# ALWAYS set DB_SSL_REJECT_UNAUTHORIZED=true with a valid CA cert in production.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# DocuSign Connect HMAC secret — copy from your DocuSign Connect configuration.
# Required for the /api/provision/docusign-webhook endpoint.
# Leave blank to disable webhook (returns 503). Never commit the real value.
DOCUSIGN_CONNECT_SECRET=
