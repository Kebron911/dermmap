# Development Dockerfile with Vite hot reload
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies
RUN npm install

# Expose Vite port
EXPOSE 5173

# Start Vite dev server (with host flag to allow external connections)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
